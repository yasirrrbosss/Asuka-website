# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Admin auth (server-only, no NEXT_PUBLIC_ prefix)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
# Generate with: openssl rand -hex 32
ADMIN_TOKEN_SECRET=change-me-to-a-random-32-byte-hex-string

# Telegram bot for order notifications (replaces /api/notify-order WhatsApp relay)
# 1. Create bot via @BotFather → /newbot → get token
# 2. Create private group, add bot + admins, send any message
# 3. Visit https://api.telegram.org/bot<TOKEN>/getUpdates and find chat.id (negative for groups)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
