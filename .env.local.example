# Public site URL — used for social/OG image metadata (absolute URLs when shared).
# Set to your real production domain. Defaults to the Firebase Hosting URL.
NEXT_PUBLIC_SITE_URL=

# NOTE: the NEXT_PUBLIC_FIREBASE_* client config is no longer needed — the
# browser never talks to Firebase directly. All Firestore access (catalog,
# orders, admin) goes through server routes using FIREBASE_SERVICE_ACCOUNT.

# Admin auth (server-only, no NEXT_PUBLIC_ prefix)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
# Generate with: openssl rand -hex 32
ADMIN_TOKEN_SECRET=change-me-to-a-random-32-byte-hex-string

# Firebase Admin SDK service account (server-only). REQUIRED — all order writes,
# stock decrements, order tracking, and admin operations run through the Admin SDK
# so the client Firestore rules can deny all writes and order reads.
# Firebase console → Project Settings → Service accounts → Generate new private key.
# Paste the downloaded JSON as a single line (or base64-encode it) here.
FIREBASE_SERVICE_ACCOUNT=

# Telegram bot for order notifications (replaces /api/notify-order WhatsApp relay)
# 1. Create bot via @BotFather → /newbot → get token
# 2. Create private group, add bot + admins, send any message
# 3. Visit https://api.telegram.org/bot<TOKEN>/getUpdates and find chat.id (negative for groups)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
